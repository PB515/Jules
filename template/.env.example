# Copy to .env.local and fill in real values. Never commit .env.local.
# See docs/runbooks/secrets.md — secrets live here only, never in chat or code.

# --- Supabase (required) ---
# Public — safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-only. Bypasses RLS. Must NEVER get a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (migrations only; not read by the app at runtime) ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Payments adapter (optional; lib/integrations/payments) ---
# PAYMENTS_PROVIDER=razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- Shipping adapter (optional; lib/integrations/shipping) ---
# SHIPPING_PROVIDER=shiprocket
